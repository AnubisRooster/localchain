# ─────────────────────────────────────────────────────────────
# LocalChain – Environment Configuration
#
# Copy this file to .env and update values for your environment.
#   cp .env.example .env
#
# Required for all environments:
#   CHAIN_ID, SIGNER_KEY, VALIDATOR_SHARED_SECRET
# ─────────────────────────────────────────────────────────────

# ── Chain Configuration ────────────────────────────────────
CHAIN_ID=localchain
CHAIN_HOME=${HOME}/.localchaind
CHAIN_BINARY=${HOME}/go/bin/localchaind
SIGNER_KEY=validator
KEYRING_BACKEND=test

# ── Network Ports ──────────────────────────────────────────
P2P_PORT=26656
RPC_PORT=26657
REST_PORT=1317
PROM_PORT=26660
API_PORT=4000
DASHBOARD_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ── API Configuration ──────────────────────────────────────
API_HOST=0.0.0.0
NODE_POLL_INTERVAL_MS=30000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Validator Registration ─────────────────────────────────
# Shared secret for validator self-registration
VALIDATOR_SHARED_SECRET=change-this-to-a-secure-secret

# ── TLS Configuration ──────────────────────────────────────
TLS_ENABLED=0
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── UPnP Configuration ─────────────────────────────────────
UPNP_ENABLED=0
UPNP_DISCOVERY_INTERVAL_MS=300000

# ── Multi-Tenant ───────────────────────────────────────────
TENANT_REQUIRED=0

# ── Resource Limits (Docker Production) ────────────────────
VALIDATOR_CPU=2.0
VALIDATOR_MEM=2G
API_CPU=1.0
API_MEM=1G
DASHBOARD_CPU=0.5
DASHBOARD_MEM=512M

# ── Monitoring ─────────────────────────────────────────────
PROM_RETENTION=7d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── P2P Network ────────────────────────────────────────────
SEEDS=
PERSISTENT_PEERS=

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=plain
